{
  "name": "newsletter-fisuc",
  "productName": "FISUC Newsletter",
  "version": "1.1.0",
  "description": "Editor visual local para crear, previsualizar y enviar newsletters HTML de FISUC.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server.mjs",
    "dev:watch": "nodemon server.mjs",
    "desktop:dev": "electron-forge start",
    "desktop:package": "electron-forge package",
    "desktop:make": "electron-forge make",
    "desktop:package:mac": "electron-forge package --platform=darwin",
    "desktop:make:mac": "electron-forge make --platform=darwin"
  },
  "keywords": [
    "newsletter",
    "fisuc",
    "mjml",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "html-to-text": "^9.0.5",
    "juice": "^9.1.0",
    "mjml": "^4.15.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.0",
    "nodemon": "^3.1.11",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "electron": "^37.2.0"
  }
